# Supabase Configuration
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only environment variables (never expose to browser)
# Use only in .env.local (development) or Vercel/deployment settings (production)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Application Configuration
NEXT_PUBLIC_APP_NAME=NexxoHub
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=1.0.0

# Integrações opcionais e exclusivamente server-side
OPENAI_API_KEY=
ASAAS_API_KEY=

# Playwright (use somente uma conta exclusiva de staging)
PLAYWRIGHT_TEST_BASE_URL=http://localhost:3000
PLAYWRIGHT_TEST_EMAIL=teste@example.com
PLAYWRIGHT_TEST_PASSWORD=Test1234!

# Node Environment
NODE_ENV=development
