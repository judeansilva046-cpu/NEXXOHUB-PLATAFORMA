    "@supabase/supabase-js": "2.108.2",
    "@tanstack/react-query": "5.45.0",
    "autoprefixer": "10.4.19",
    "axios": "1.18.1",
    "class-variance-authority": "0.7.0",
    "clsx": "2.1.1",
    "date-fns": "3.6.0",
